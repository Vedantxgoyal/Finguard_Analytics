# Copy this file to .env.local and fill in the real value.
# .env.local is gitignored by default in every Next.js project — never
# commit real values, only this template (same pattern as the backend's
# .env / .env.example split).

# URL of the FastAPI backend, read SERVER-SIDE ONLY (no NEXT_PUBLIC_
# prefix — this value is never sent to the browser; see the architecture
# note in next.config.mjs and lib/api.ts for why client components go
# through this app's own /api/* routes instead of calling FastAPI
# directly).
#
# Local development (FastAPI running via `uvicorn backend.main:app --port 8000`):
BACKEND_API_URL=http://localhost:8000

# Production (Render/Railway deployment URL):
# BACKEND_API_URL=https://your-backend-service.onrender.com
